<?xml version="1.0" encoding="utf-8"?>
<!--
  Consumer-side package resolution:
   - "local-artifacts" points at the repo's artifacts/ folder, where
     build\package.cmd drops CurlHttpClient.*.nupkg.
   - globalPackagesFolder is local to this solution so a rebuilt 1.0.0
     package is picked up by deleting consumer\packages (no stale copies
     hiding in the machine-wide NuGet cache).
-->
<configuration>
  <config>
    <add key="globalPackagesFolder" value="packages" />
  </config>
  <packageSources>
    <clear />
    <add key="local-artifacts" value="..\artifacts" />
    <add key="nuget.org" value="https://api.nuget.org/v3/index.json" />
  </packageSources>
</configuration>
