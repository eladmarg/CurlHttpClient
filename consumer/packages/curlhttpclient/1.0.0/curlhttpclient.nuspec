<?xml version="1.0" encoding="utf-8"?>
<package xmlns="http://schemas.microsoft.com/packaging/2013/05/nuspec.xsd">
  <metadata>
    <id>CurlHttpClient</id>
    <version>1.0.0</version>
    <authors>CustomHttpClient</authors>
    <license type="expression">MIT</license>
    <licenseUrl>https://licenses.nuget.org/MIT</licenseUrl>
    <description>HttpMessageHandler backed by a bundled libcurl + OpenSSL native bridge. Provides modern TLS (1.2/1.3) on hosts whose Schannel cannot, e.g. Windows Server 2012 R2.</description>
    <tags>httpclient libcurl openssl tls httpmessagehandler</tags>
    <repository type="git" />
    <dependencies>
      <group targetFramework="net10.0">
        <dependency id="Microsoft.Extensions.Logging.Abstractions" version="10.0.0" exclude="Build,Analyzers" />
      </group>
    </dependencies>
  </metadata>
</package>